[Unit]
Description=OKYpY invoice-agent approval web app (waitress, port 8091)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/okypy/app/invoice-agent
EnvironmentFile=-/opt/okypy/env
ExecStart=/opt/okypy/venv/bin/python serve_approvals.py
Restart=on-failure
RestartSec=5
User=okypy
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
